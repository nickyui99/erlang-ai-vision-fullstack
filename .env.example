APP_ENV=development
APP_NAME=Erlang AI Vision Backend
APP_VERSION=0.1.0
API_PREFIX=/api/v1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000,http://localhost:5173,http://localhost:8080,http://localhost:8081,http://localhost:8082,http://localhost:8083,http://localhost:8084,http://localhost:8085
CORS_ALLOWED_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$

# Local dev default (SQLite). Production uses Alibaba ApsaraDB RDS PostgreSQL:
#   DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@pgm-xxxx.pg.rds.aliyuncs.com:5432/erlang
# URL-encode the password if it contains special characters (@ : / % #).
# All datetimes are stored UTC; clients convert to local time for display.
DATABASE_URL=sqlite+aiosqlite:///./data/erlang_demo.db

# Production Google Secret Manager integration. Keep the service-account JSON
# outside this repository. Development reads this file directly; backend.ps1
# reads it locally and transports encoded credentials to production ECI. The
# credential to ECI without copying it into the image or Git. The reader account
# needs secretAccessor only on these two secrets. Values from erlang-db-secrets
# override duplicates from erlang-prod-secrets. Never add the DB superuser secret.
GOOGLE_SECRET_MANAGER_PROJECT=sentineledge-e069b
GOOGLE_SECRET_MANAGER_SECRETS=erlang-prod-secrets,erlang-db-secrets
GOOGLE_SECRET_MANAGER_CREDENTIALS_FILE=C:\Users\your-user\.secrets\sentineledge-eci-secret-reader.json

# Generated by backend.ps1 for production ECI. Do not set or commit this locally.
GOOGLE_SECRET_MANAGER_CREDENTIALS_B64=

# Alibaba Cloud access key for deployment (OSS media bucket, ACR, ECI) only.
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
ALICLOUD_OSS_ENDPOINT=oss-ap-southeast-1.aliyuncs.com
ALICLOUD_OSS_BUCKET=
ALICLOUD_OSS_SECURE=true

FIREBASE_PROJECT_ID=change-me
GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\firebase-service-account.json

SESSION_SECRET_KEY=change-me
SESSION_COOKIE_NAME=erlang_session
SESSION_EXPIRE_MINUTES=1440

# Push alerts (Milestone 8) - delivered via Firebase Cloud Messaging, which
# reuses FIREBASE_PROJECT_ID / GOOGLE_APPLICATION_CREDENTIALS above.
ALERTS_ENABLED=true
ALERT_MIN_SEVERITY=high

# AI verification (Milestone 9) - Qwen Cloud via DashScope OpenAI-compatible API.
# Opt-in: off by default. Without QWEN_API_KEY the service uses a deterministic
# mock verdict so the pipeline is demoable offline.
VERIFICATION_ENABLED=false
VERIFY_MIN_SEVERITY=high
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-vl-max
# Text model used to compile plain-language agent rules into edge configs.
# Falls back to a deterministic keyword compiler when QWEN_API_KEY is unset.
QWEN_COMPILER_MODEL=qwen-plus
QWEN_TIMEOUT_SECONDS=20
QWEN_MAX_TOOL_TURNS=4
# MCP actuation guardrails (9B): the verification agent may pan the camera, but
# only this many times per event and no faster than this interval.
MCP_MAX_PANS_PER_EVENT=3
MCP_MIN_SECONDS_BETWEEN_PANS=5

# Demo simulation (demo/judge account only): the backend plays pre-extracted
# frames into a camera's live view and triages them with the Qwen-VL API, so a
# demo needs no laptop edge. Only cameras whose id starts with the prefix below
# and that have a frame folder are simulated; normal accounts are unaffected.
# Requires a Qwen-VL model (QWEN_MODEL above). See README "Demo Simulation".
DEMO_SIMULATION_ENABLED=false
DEMO_SIM_DEVICE_PREFIX=dev_judge_
# Where extracted frames live. Empty -> <repo>/data/demo_frames. The Docker
# image sets this to the path it copies frames into (/app/demo_frames).
DEMO_FRAMES_DIR=
DEMO_SIM_FPS=10
DEMO_SIM_TRIAGE_INTERVAL_SECONDS=15
# Faster cadence until the first detection lands (snappier when a camera opens).
DEMO_SIM_FIRST_TRIAGE_INTERVAL_SECONDS=3
DEMO_SIM_EVENT_COOLDOWN_SECONDS=45
DEMO_SIM_IDLE_TIMEOUT_SECONDS=30

SIGNED_URL_TTL_SECONDS=900
MEDIA_RETENTION_DAYS=7
DAILY_RECORDING_RETENTION_HOURS=72
# Retention sweep cadence (marks expired DB rows; <= 0 disables). OSS bytes are
# deleted by bucket lifecycle rules — keep them in sync via media-bucket.ps1.
MEDIA_SWEEP_INTERVAL_SECONDS=3600
