APP_ENV=development
APP_NAME=SentinelEdge Backend
APP_VERSION=0.1.0
API_PREFIX=/api/v1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000,http://localhost:5173,http://localhost:8080,http://localhost:8081,http://localhost:8082,http://localhost:8083,http://localhost:8084,http://localhost:8085
CORS_ALLOWED_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$

# Local dev default (SQLite). Production uses Alibaba ApsaraDB RDS PostgreSQL:
#   DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@pgm-xxxx.pg.rds.aliyuncs.com:5432/sentineledge
# URL-encode the password if it contains special characters (@ : / % #).
# All datetimes are stored UTC; clients convert to local time for display.
DATABASE_URL=sqlite+aiosqlite:///./data/sentineledge_demo.db

# Optional Alibaba Cloud KMS Secrets Manager integration.
# Secret value may be JSON with SESSION_SECRET_KEY, QWEN_API_KEY,
# GOOGLE_APPLICATION_CREDENTIALS_JSON, and the database credentials as either
# a full DATABASE_URL or discrete RDS_HOST / RDS_PORT / RDS_DB / RDS_USER /
# RDS_PASSWORD keys (preferred: user/password are URL-encoded automatically
# when the DSN is assembled). KMS values take precedence over this file,
# except DATABASE_URL: an explicitly exported DATABASE_URL env var always
# wins, so tests and local tooling can never be silently redirected to the
# production database. Leave ALICLOUD_KMS_SECRET_NAME empty to use the
# explicit local env vars below instead. Multiple secret names may be given
# comma-separated; they are merged in order (later names win on duplicates).
ALICLOUD_KMS_SECRET_NAME=
ALICLOUD_REGION_ID=ap-southeast-3
ALICLOUD_KMS_ENDPOINT=
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=

FIREBASE_PROJECT_ID=change-me
GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\firebase-service-account.json

SESSION_SECRET_KEY=change-me
SESSION_COOKIE_NAME=sentineledge_session
SESSION_EXPIRE_MINUTES=1440

# Push alerts (Milestone 8) - delivered via Firebase Cloud Messaging, which
# reuses FIREBASE_PROJECT_ID / GOOGLE_APPLICATION_CREDENTIALS above.
ALERTS_ENABLED=true
ALERT_MIN_SEVERITY=high

# AI verification (Milestone 9) - Qwen Cloud via DashScope OpenAI-compatible API.
# Opt-in: off by default. Without QWEN_API_KEY the service uses a deterministic
# mock verdict so the pipeline is demoable offline.
VERIFICATION_ENABLED=false
VERIFY_MIN_SEVERITY=high
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-vl-max
QWEN_TIMEOUT_SECONDS=20
QWEN_MAX_TOOL_TURNS=4
# MCP actuation guardrails (9B): the verification agent may pan the camera, but
# only this many times per event and no faster than this interval.
MCP_MAX_PANS_PER_EVENT=3
MCP_MIN_SECONDS_BETWEEN_PANS=5

SIGNED_URL_TTL_SECONDS=900
MEDIA_RETENTION_DAYS=7
DAILY_RECORDING_RETENTION_HOURS=72